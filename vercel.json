{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "pc-video.mp4",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/pc-video.mp4",
      "dest": "/pc-video.mp4"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}